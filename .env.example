# =====================================================================
# Promptbanken – exempel på miljövariabler.
# Kopiera till .env (backend/Docker) eller .env.local (Vite-frontend).
# LÄGG ALDRIG in riktiga hemligheter i .env.example – den versioneras.
# =====================================================================

# --- Frontend (Vite) -------------------------------------------------
# Bakas in i den publika bundlen. Endast PUBLIKA nycklar här.
# Använd ALDRIG service_role eller andra hemliga nycklar i frontend.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- Backend: LLM-gateway (FastAPI) ----------------------------------
OLLAMA_BASE_URL=http://host.docker.internal:11434
MODEL_TIMEOUT_SECONDS=300
# Kommaseparerad lista över tillåtna origins för CORS.
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Valfri molnprovider (proxas via backend, aldrig direkt från frontend).
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Backend: admin-API + providerhemligheter ------------------------
# Lång, slumpad hemlighet. Admin-API:t är inaktiverat (503) om den saknas.
ADMIN_PANEL_TOKEN=
# Krypteringsnyckel för lagrade providerhemligheter (provider_secrets.db).
PROVIDER_ENCRYPTION_KEY=

# --- Seed-script för testanvändare (körs aldrig i produktion) ---------
# Läggs i .env.seed.local (gitignore:ad), INTE här.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# TEST_USER_PASSWORD=
